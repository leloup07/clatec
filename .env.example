# ═══════════════════════════════════════════════════════════
# CLATEC — Environment Variables (Consolidated)
# ═══════════════════════════════════════════════════════════
# Copy to .env.local and fill in values

# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM (Anthropic Claude) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@clatec.consulting

# ─── Stripe (prepayment) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Booking ──────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/clatec/consultation

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://clatec.consulting
ADMIN_EMAIL=admin@clatec.consulting

# ─── Admin (replace with Supabase Auth in production) ─────
NEXT_PUBLIC_ADMIN_PASSWORD=change-this-immediately

# ─── Analytics (optional) ─────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
